// ─── useScoreColor Hook ────────────────────────────────────────────
import {
  getSaturationColor,
  getFrictionColor,
  getSaturationStatus,
  getFrictionStatus,
} from "@/lib/utils"

export function useScoreColor(score, type = "exploration") {
  const color =
    type === "exploration"
      ? getSaturationColor(score)
      : getFrictionColor(score)

  const status =
    type === "exploration"
      ? getSaturationStatus(score)
      : getFrictionStatus(score)

  return { color, status }
}

// ─── useFormValidation Hook ────────────────────────────────────────
export function useFormValidation() {
  const [errors, setErrors] = useState({})

  const validate = useCallback((fields) => {
    const newErrors = {}

    if (fields.topic !== undefined && !fields.topic.trim()) {
      newErrors.topic = "Topic is required"
    }

    if (fields.category !== undefined && !fields.category) {
      newErrors.category = "Category is required"
    }

    if (
      fields.password !== undefined &&
      fields.password.length < 8
    ) {
      newErrors.password = "Password must be at least 8 characters"
    }

    if (
      fields.confirmPassword !== undefined &&
      fields.password !== fields.confirmPassword
    ) {
      newErrors.confirmPassword = "Passwords do not match"
    }

    setErrors(newErrors)
    return Object.keys(newErrors).length === 0
  }, [])

  const clearError = useCallback((field) => {
    setErrors((prev) => {
      const updated = { ...prev }
      delete updated[field]
      return updated
    })
  }, [])

  const clearAll = useCallback(() => setErrors({}), [])

  return { errors, validate, clearError, clearAll }
}
