import { GoogleGenerativeAI } from "@google/generative-ai";

const genAI = new GoogleGenerativeAI("AIzaSyB4qZ9V_EgtOAXVM8Nywm3aBPtYYZsJGwc");
const model = genAI.getGenerativeModel({ model: "gemini-1.5-flash" });

function parseJSON(text) {
  const cleaned = text.replace(/```json/gi, "").replace(/```/g, "").trim();
  const match = cleaned.match(/\{[\s\S]*\}/);
  if (!match) throw new Error("Could not parse AI response");
  return JSON.parse(match[0]);
}

// ── Exploration Saturation ─────────────────────────────────────────
export async function analyzeExplorationSaturation(data) {
  const {
    topic, category, optionsExplored, hoursSpent,
    sourcesConsulted, comparisonsMade, topOptions, additionalNotes,
  } = data;

  const optionsText = topOptions.length > 0
    ? topOptions.map((o) => `"${o.name}" (confidence: ${o.confidence}%)`).join(", ")
    : "None specified";

  const prompt = `
You are an expert Decision Intelligence AI.

Analyze this research data:
- Topic: "${topic}"
- Category: ${category}
- Options Explored: ${optionsExplored}
- Hours Spent: ${hoursSpent}
- Sources Consulted: ${sourcesConsulted}
- Comparisons Made: ${comparisonsMade}
- Top Options: ${optionsText}
- Notes: "${additionalNotes || "None"}"

Scoring:
0-29: Under-Researched
30-59: Adequately Researched  
60-79: Well-Researched
80-100: Over-Researched

Return ONLY valid JSON:
{
  "saturationScore": <0-100>,
  "status": "<status>",
  "recommendation": "<2-3 paragraphs>",
  "detailedAnalysis": "<2-3 paragraphs>",
  "keyInsights": ["<insight1>","<insight2>","<insight3>"],
  "nextSteps": ["<step1>","<step2>","<step3>"]
}`;

  try {
    const result = await model.generateContent(prompt);
    return parseJSON(result.response.text());
  } catch (err) {
    console.error("Gemini exploration error:", err);
    throw new Error("Analysis failed. Please try again.");
  }
}

// ── Cognitive Friction ─────────────────────────────────────────────
export async function analyzeCognitiveFriction(data) {
  const {
    topic, category, steps, theoryPracticeRatio,
    contextSwitches, feedbackDelay, additionalNotes,
  } = data;

  const stepsText = steps.length > 0
    ? steps.map((s, i) =>
        `Step ${i + 1}: "${s.name}" | ${s.type} | Difficulty: ${s.difficulty}/100 | Feedback: ${s.hasFeedback ? "Yes" : "No"}`
      ).join("\n")
    : "No steps defined";

  const prompt = `
You are an expert Cognitive Load AI.

Analyze this learning/workflow data:
- Topic: "${topic}"
- Category: ${category}
- Steps:
${stepsText}
- Theory/Practice: ${theoryPracticeRatio}% theory / ${100 - theoryPracticeRatio}% practice
- Context Switches: ${contextSwitches}
- Feedback Delay: ${feedbackDelay} hours
- Notes: "${additionalNotes || "None"}"

Scoring:
0-29: Low Friction
30-54: Moderate Friction
55-74: High Friction
75-100: Critical Friction

Return ONLY valid JSON:
{
  "frictionScore": <0-100>,
  "frictionDrivers": ["<driver1>","<driver2>","<driver3>"],
  "recommendation": "<2-3 paragraphs>",
  "detailedAnalysis": "<2-3 paragraphs>",
  "optimizationTips": ["<tip1>","<tip2>","<tip3>"],
  "estimatedImprovementPotential": "<description>"
}`;

  try {
    const result = await model.generateContent(prompt);
    return parseJSON(result.response.text());
  } catch (err) {
    console.error("Gemini friction error:", err);
    throw new Error("Analysis failed. Please try again.");
  }
}
